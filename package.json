{
  "name": "taxo-store-shell",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build-lib": "ng build @myrmidon/taxo-store-api && ng build @myrmidon/taxo-store-editor && ng build @myrmidon/taxo-store-picker && ng build @myrmidon/cadmus-part-taxo-store-nodes"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "dependencies": {
    "@angular/cdk": "~22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "~22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@myrmidon/auth-jwt-admin": "^9.0.0",
    "@myrmidon/auth-jwt-login": "^9.0.0",
    "@myrmidon/cadmus-api": "^15.0.0",
    "@myrmidon/cadmus-core": "^13.0.0",
    "@myrmidon/cadmus-item-editor": "^17.0.0",
    "@myrmidon/cadmus-refs-lookup": "^11.0.0",
    "@myrmidon/cadmus-state": "^16.0.0",
    "@myrmidon/cadmus-ui": "^17.0.0",
    "@myrmidon/ngx-mat-tools": "^2.0.0",
    "@myrmidon/ngx-tools": "^3.0.0",
    "@myrmidon/paged-data-browsers": "^6.0.0",
    "rxjs": "~7.8.0",
    "ts-md5": "^2.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
