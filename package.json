{
  "name": "taxo-store-shell",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build-lib": "ng build @myrmidon/taxo-store-api && ng build @myrmidon/taxo-store-editor && ng build @myrmidon/taxo-store-picker"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@angular/cdk": "~21.1.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.1",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@myrmidon/auth-jwt-admin": "^8.0.3",
    "@myrmidon/auth-jwt-login": "^8.0.3",
    "@myrmidon/cadmus-refs-lookup": "^10.0.6",
    "@myrmidon/ngx-tools": "^2.0.2",
    "@myrmidon/paged-data-browsers": "^5.1.3",
    "rxjs": "~7.8.0",
    "ts-md5": "^2.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/localize": "^21.1.1",
    "@angular/material": "^21.1.1",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
